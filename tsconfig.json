{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "utils/insertDemoData.js", "app/search/page.js", "app/api/socket/route.js", "components/Header.js", "components/AddToWishlistBtn.js", "app/api/auth/[...nextauth]/route.js", "app/shop/[[...slug]]/page.tsx", "components/Products.js", "app/(dashboard)/admin/products/[id]/page.js", "components/ProductsSection.tsx"],
  "exclude": ["node_modules"]
}
